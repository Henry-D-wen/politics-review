    <script>
        // 答案数据
        const answers = {
            q1: { correct: 'C', type: 'single' },
            q2: { correct: ['A', 'B', 'C'], type: 'multi' },
            q3: { correct: 'A', type: 'single' },
            q4: { correct: 'B', type: 'single' }
        };

        // 用户选择状态
        const userSelections = {};

        // 切换侧边栏
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
        }

        // 切换模块展开/收起
        function toggleModule(header) {
            header.classList.toggle('expanded');
            const topics = header.nextElementSibling;
            topics.classList.toggle('expanded');
        }

        // 显示对应内容
        function showContent(id, element) {
            // 更新导航状态
            document.querySelectorAll('.nav-topic').forEach(t => t.classList.remove('active'));
            element.classList.add('active');
            
            // 更新面包屑
            const module = element.closest('.nav-module');
            const moduleName = module.querySelector('.nav-module-title').textContent.trim();
            document.querySelector('.breadcrumb').innerHTML = `📚 ${moduleName} / <span>${element.textContent}</span>`;
            
            // 这里可以根据id加载不同内容
            console.log('显示内容:', id);
        }

        // 切换视图
        function switchView(view, btn) {
            document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            if (view === 'knowledge') {
                document.getElementById('knowledgeView').classList.remove('hidden');
                document.getElementById('quizView').classList.add('hidden');
            } else {
                document.getElementById('knowledgeView').classList.add('hidden');
                document.getElementById('quizView').classList.remove('hidden');
            }
        }

        // 单选题选择
        function selectOption(qId, option, element) {
            if (answers[qId].type === 'multi') return;
            
            const container = document.getElementById(qId + '-options');
            container.querySelectorAll('.quiz-option').forEach(o => o.classList.remove('selected'));
            element.classList.add('selected');
            userSelections[qId] = option;
        }

        // 多选题选择
        function toggleMultiOption(qId, option, element) {
            if (!userSelections[qId]) userSelections[qId] = [];
            
            const index = userSelections[qId].indexOf(option);
            if (index > -1) {
                userSelections[qId].splice(index, 1);
                element.classList.remove('selected');
            } else {
                userSelections[qId].push(option);
                element.classList.add('selected');
            }
        }

        // 检查单选答案
        function checkAnswer(qId) {
            const answer = answers[qId];
            const container = document.getElementById(qId + '-options');
            const options = container.querySelectorAll('.quiz-option');
            
            options.forEach(opt => {
                const label = opt.querySelector('.quiz-option-label').textContent;
                opt.classList.remove('selected');
                
                if (label === answer.correct) {
                    opt.classList.add('correct');
                } else if (userSelections[qId] === label) {
                    opt.classList.add('wrong');
                }
            });
            
            document.getElementById(qId + '-answer').classList.add('show');
        }

        // 检查多选答案
        function checkMultiAnswer(qId) {
            const answer = answers[qId];
            const container = document.getElementById(qId + '-options');
            const options = container.querySelectorAll('.quiz-option');
            const userAns = userSelections[qId] || [];
            
            options.forEach(opt => {
                const label = opt.querySelector('.quiz-option-label').textContent;
                opt.classList.remove('selected');
                
                if (answer.correct.includes(label)) {
                    opt.classList.add('correct');
                } else if (userAns.includes(label)) {
                    opt.classList.add('wrong');
                }
            });
            
            document.getElementById(qId + '-answer').classList.add('show');
        }

        // 重置试题
        function resetQuiz(qId) {
            const container = document.getElementById(qId + '-options');
            container.querySelectorAll('.quiz-option').forEach(opt => {
                opt.classList.remove('selected', 'correct', 'wrong');
            });
            document.getElementById(qId + '-answer').classList.remove('show');
            delete userSelections[qId];
        }

        // 搜索功能
        function handleSearch(value) {
            console.log('搜索:', value);
            // 这里可以实现实际的搜索逻辑
        }
    </script>
